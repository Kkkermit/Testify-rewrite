{
  "name": "testify",
  "version": "1.0.0",
  "description": "Open source Discord bot for server management, moderation, and fun features.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:nodemon": "nodemon src/index.js",
    "prod": "node src/index.js",
    "dev": "cross-env NODE_ENV=development node src/index.js",
    "setup-env": "node src/scripts/setupEnvFile.js",
    "lint": "node -r module-alias/register src/scripts/lintRunner.js",
    "lint:fix": "node -r module-alias/register src/scripts/lintRunner.js --fix",
    "commit": "node -r module-alias/register src/scripts/commitRunner.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "Kkkermit",
  "license": "MIT",
  "dependencies": {
    "ascii-table": "^0.0.9",
    "axios": "^1.7.7",
    "discord.js": "14.25.1",
    "dotenv": "^16.4.5",
    "fs": "^0.0.1-security",
    "module-alias": "2.2.3",
    "mongoose": "^6.0.12",
    "path": "^0.12.7"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@jest/globals": "30.2.0",
    "cross-env": "7.0.3",
    "eslint": "10.0.2",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "jest": "30.2.0"
  },
  "_moduleAliases": {
    "@root": ".",
    "@src": "src",
    "@utils": "src/utils",
    "@config": "src/config.js",
    "@commands": "src/commands",
    "@events": "src/events",
    "@functions": "src/functions",
    "@schemas": "src/schemas",
    "@lib": "src/lib"
  }
}
